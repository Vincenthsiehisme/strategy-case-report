        "tension": {
          "status": "estimated",
          "confirmed": [],
          "estimated": [
            {
              "claim": "推論內容",
              "proxy": "使用的代理變數",
              "assumption": "這個推論成立的假設條件",
              "source_ref": "來源"
            }
          ]
        },
        "boundary": {
          "status": "unknown",
          "confirmed": [],
          "estimated": []
