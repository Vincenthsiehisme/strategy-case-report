          "headline": "頁面標題",
          "footer": "頁尾收束句",
          "confirmed": [
            {
              "claim": "已驗證事實（來自 root_evidence）",
              "source_ref": "來源 label"
            }
          ],
          "estimated": [
            {
              "claim": "初步判讀",
              "proxy": "代理變數",
              "assumption": "成立假設"
            }
