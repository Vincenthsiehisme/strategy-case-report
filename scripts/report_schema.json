        }
      ],

      "sources": [
        {
          "label": "資訊標注",
          "source": "來源名稱或 URL",
          "type": "official",
          "_type_note": "official / major_media / secondary_media / proxy（v2.6 新增，代理變數來源）"
        }
      ]
    }
  ],

  "conclusion": {
    "cross_case_insight": "從三案提煉出的跨案洞察（不是摘要，是更高一層的判斷）",
    "action_prompt": "對讀者的行動建議或思考提問",
    "key_unknowns": [
      "三案中最關鍵的待補資料 1",
      "待補資料 2（選填，最多 3 條）"
    ],
    "_optional": true,
    "_optional_note": "Sprint Mode 可設為 null。key_unknowns 是整份報告的知識邊界聲明。"
  }
