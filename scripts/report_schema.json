        "what_to_steal": {
          "headline": "頁面標題",
          "footer": "頁尾收束句",
          "methods": [
            {
              "title": "動詞開頭的方法標題",
              "scenarios": [
                {
                  "condition": "在 A 條件下（品牌有直客基礎）",
