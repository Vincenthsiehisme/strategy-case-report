    "date": "2026-03-20",
    "mode": "full",
    "_mode_note": "full 或 sprint"
  },

  "visual": {
    "colors": {
      "bg_primary": "#1a1a1a",
      "bg_secondary": "#2a2a2a",
      "text_primary": "#f0f0f0",
      "text_secondary": "#999999",
      "accent": "#e8c547"
    },
    "fonts": {
      "display": "Playfair Display",
      "body": "Lato",
      "_note": "必須是 Google Fonts 可用的字體名稱"
    },
    "mood": "沉穩優雅",
    "_mood_note": "銳利張力 / 沉穩優雅 / 專業精準 / 高冷奢華"
